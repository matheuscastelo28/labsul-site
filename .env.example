# Copie este arquivo para env.local (uso local) e configure as mesmas
# variaveis no painel do Vercel, em Project Settings, Environment Variables,
# para o ambiente de producao. Nunca coloque valores reais neste arquivo
# de exemplo, e nunca faca commit do seu arquivo de variaveis reais.

# Chave da API da OpenAI, usada pela funcao api/assistant.js
OPENAI_API_KEY=

# URL e chave de servico (service role) do seu projeto Supabase.
# A service role key tem acesso total ao banco: mantenha-a apenas
# nas variaveis de ambiente do servidor, nunca no codigo do frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Um token simples escolhido por voce, usado para proteger o acesso
# a pagina do Assistente IA e as rotas api/assistant e api/upload.
ADMIN_TOKEN=
